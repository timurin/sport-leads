# Copy to `.env` in the repository root for Docker Compose and local backend.
# Do not commit real secrets.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sport_leads
POSTGRES_USER=sport_leads
POSTGRES_PASSWORD=change_me_local_only

# Optional: override SQLAlchemy URL (otherwise built from POSTGRES_* above)
# DATABASE_URL=postgresql+psycopg2://sport_leads:change_me_local_only@localhost:5432/sport_leads

TZ=Europe/Moscow

# pgAdmin (Docker Compose only)
PGADMIN_EMAIL=admin@example.local
PGADMIN_PASSWORD=change_me_local_only
PGADMIN_PORT=5050

# Optional API logging (roadmap 0.3.2)
# LOG_LEVEL=info
